window-rule {
    match app-id="zen" title="^Picture-in-Picture$"
    open-floating true
}

window-rule {
    match app-id="org.gnome.Nautilus" title="Select file to Run"
    open-floating true
}

window-rule {
    match app-id="kitty"
    default-column-width { proportion 0.5; }
}

window-rule {
    variable-refresh-rate true;
}

window-rule {
    match is-active=false;
    opacity 0.95;
}

window-rule {
    match is-active=true;
    opacity 0.98;
}

